<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TravelPlanner | Plan Your Next Adventure</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/home.css" />
  <style>
    .navbar-home .logo { display:flex; align-items:center; gap:12px; }
    .navbar-home .logo-icon { width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-size:20px; }
    .navbar-home .logo-text { display:flex;flex-direction:column; }
    .navbar-home .logo-text span { font-weight:800;font-size:17px;color:var(--text);line-height:1.2; }
    .navbar-home .logo-text small { font-size:10px;color:var(--text3);margin-top:-2px; }
    .navbar-home .logo a { text-decoration:none;display:flex;align-items:center;gap:12px; }
  </style>
</head>
<body>
  <nav class="navbar-home" id="navbar">
    <div class="logo">
      <a href="/">
        <div class="logo-icon">✈️</div>
        <div class="logo-text">
          <span>TravelPlanner</span>
          <small>Explore the world</small>
        </div>
      </a>
    </div>
    <div class="nav-links" id="navLinks">
      <a href="#continents">Continents</a>
      <a href="#stats">Stats</a>
      <a href="/about">About</a>
      <% if (!user) { %>
        <a href="/login" class="btn-login">Login</a>
        <a href="/register" class="btn btn-primary btn-sm" style="padding:8px 20px">Sign Up</a>
      <% } else { %>
        <a href="/dashboard" class="btn-login">Dashboard</a>
        <a href="/logout" class="btn btn-ghost btn-sm">Logout</a>
      <% } %>
    </div>
    <button class="nav-hamburger" id="navHamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <section class="hero-section">
    <div class="hero-content">
      <h1 class="hero-title">Plan Your Next Adventure</h1>
      <p class="hero-subtitle">Organize trips, track visited cities, and explore the world — all in one place.</p>
      <div class="hero-buttons">
        <% if (!user) { %>
          <a href="#continents" class="btn btn-outline-light btn-large">Explore Continents</a>
        <% } else { %>
          <a href="/dashboard" class="btn btn-primary btn-large">Go to Dashboard</a>
          <a href="/trips/new" class="btn btn-outline-light btn-large">Plan a Trip</a>
        <% } %>
      </div>
    </div>
  </section>

  <section id="continents" class="continents-section">
    <h2 class="section-title">Explore Our Continents</h2>
    <p class="section-subtitle">Discover amazing destinations across the globe</p>
    <div class="continents-grid">
      <div class="continent-card fade-scroll">
        <img src="/assets/bali.jpeg" alt="Asia" class="continent-image" />
        <div class="continent-info">
          <h3 class="continent-name">🌏 Asia</h3>
          <p class="continent-desc">The largest continent, home to ancient temples, modern megacities, and diverse cultures from Japan to India.</p>
          <div class="continent-stats">
            <div class="continent-stat"><div class="continent-stat-number">48+</div><div class="continent-stat-label">Countries</div></div>
            <div class="continent-stat"><div class="continent-stat-number">4.7B</div><div class="continent-stat-label">Population</div></div>
          </div>
        </div>
      </div>
      <div class="continent-card fade-scroll">
        <img src="/assets/greece2.jpeg" alt="Europe" class="continent-image" />
        <div class="continent-info">
          <h3 class="continent-name">🏰 Europe</h3>
          <p class="continent-desc">Rich history, stunning architecture, and romantic cities like Paris, Rome, and Barcelona.</p>
          <div class="continent-stats">
            <div class="continent-stat"><div class="continent-stat-number">44+</div><div class="continent-stat-label">Countries</div></div>
            <div class="continent-stat"><div class="continent-stat-number">748M</div><div class="continent-stat-label">Population</div></div>
          </div>
        </div>
      </div>
      <div class="continent-card fade-scroll">
        <img src="/assets/nycc.jpeg" alt="North America" class="continent-image" />
        <div class="continent-info">
          <h3 class="continent-name">🗽 North America</h3>
          <p class="continent-desc">From the bustling streets of New York to the natural wonders of Canada and Mexico.</p>
          <div class="continent-stats">
            <div class="continent-stat"><div class="continent-stat-number">23+</div><div class="continent-stat-label">Countries</div></div>
            <div class="continent-stat"><div class="continent-stat-number">592M</div><div class="continent-stat-label">Population</div></div>
          </div>
        </div>
      </div>
      <div class="continent-card fade-scroll">
        <img src="/assets/brazil.jpeg" alt="South America" class="continent-image" />
        <div class="continent-info">
          <h3 class="continent-name">🦙 South America</h3>
          <p class="continent-desc">Amazon rainforest, Andes mountains, and vibrant cultures in Brazil, Argentina, and Peru.</p>
          <div class="continent-stats">
            <div class="continent-stat"><div class="continent-stat-number">12+</div><div class="continent-stat-label">Countries</div></div>
            <div class="continent-stat"><div class="continent-stat-number">430M</div><div class="continent-stat-label">Population</div></div>
          </div>
        </div>
      </div>
      <div class="continent-card fade-scroll">
        <img src="/assets/egypt.jpeg" alt="Africa" class="continent-image" />
        <div class="continent-info">
          <h3 class="continent-name">🦁 Africa</h3>
          <p class="continent-desc">Safaris, breathtaking landscapes, and rich heritage from Egypt to South Africa.</p>
          <div class="continent-stats">
            <div class="continent-stat"><div class="continent-stat-number">54+</div><div class="continent-stat-label">Countries</div></div>
            <div class="continent-stat"><div class="continent-stat-number">1.4B</div><div class="continent-stat-label">Population</div></div>
          </div>
        </div>
      </div>
      <div class="continent-card fade-scroll">
        <img src="/assets/australia.jpeg" alt="Australia" class="continent-image" />
        <div class="continent-info">
          <h3 class="continent-name">🐨 Australia/Oceania</h3>
          <p class="continent-desc">Island nations, unique wildlife, and stunning beaches across Australia and the Pacific.</p>
          <div class="continent-stats">
            <div class="continent-stat"><div class="continent-stat-number">14+</div><div class="continent-stat-label">Countries</div></div>
            <div class="continent-stat"><div class="continent-stat-number">42M</div><div class="continent-stat-label">Population</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="stats" class="stats-section fade-scroll">
    <div class="stats-grid">
      <div><div class="stat-number">50+</div><div class="stat-label">Countries</div></div>
      <div><div class="stat-number">200+</div><div class="stat-label">Cities</div></div>
      <div><div class="stat-number">1000+</div><div class="stat-label">Trips Planned</div></div>
      <div><div class="stat-number">24/7</div><div class="stat-label">Access Anywhere</div></div>
    </div>
  </section>

  <section class="cta-section fade-scroll">
    <h2 class="cta-title">Ready to start your journey?</h2>
    <p class="cta-text">Join thousands of travelers who organize their adventures with TravelPlanner.</p>
    <% if (!user) { %>
      <a href="/register" class="btn btn-primary btn-large">Create Free Account</a>
    <% } else { %>
      <a href="/dashboard" class="btn btn-primary btn-large">Go to Dashboard</a>
    <% } %>
  </section>

  <footer>
    <p>© 2024 TravelPlanner. All rights reserved. | Explore. Plan. Travel.</p>
  </footer>

  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 50);
    });

    const navHamburger = document.getElementById('navHamburger');
    const navLinks     = document.getElementById('navLinks');
    if (navHamburger) {
      navHamburger.addEventListener('click', () => {
        navHamburger.classList.toggle('open');
        navLinks.classList.toggle('open');
      });
    }

    const fadeElements = document.querySelectorAll('.fade-scroll');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => entry.target.classList.toggle('visible', entry.isIntersecting));
    }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
    fadeElements.forEach(el => observer.observe(el));
  </script>
</body>
</html>