<%- include('../partials/head') %>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="logo-icon">✈️</div>
      <div><h1>TravelPlanner</h1><p>Your world, your trips</p></div>
    </div>
    <h2 class="auth-title">Welcome back</h2>
    <p class="auth-sub">Sign in to continue planning</p>

    <% if (error) { %><div class="alert alert-error">⚠️ <%= error %></div><% } %>

    <form action="/login" method="POST">
      <div class="form-grid" style="gap:15px">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" required placeholder="you@example.com" />
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" required placeholder="••••••••" />
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:11px">
          Sign In
        </button>
      </div>
    </form>
    <p class="auth-footer">No account? <a href="/register">Register here</a></p>
  </div>
</div>
<%- include('../partials/foot') %>
