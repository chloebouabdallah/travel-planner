<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><%= trip.name %></div>
      <div class="topbar-actions">
        <% const isOwner = user && trip.user && trip.user._id && trip.user._id.toString() === user._id.toString(); %>
        <% const canEdit = isOwner || user.role === 'admin'; %>
        <% if (canEdit) { %>
          <a href="/trips/<%= trip._id %>/edit" class="btn btn-ghost btn-sm">✏️ Edit</a>
          <form action="/trips/<%= trip._id %>?_method=DELETE" method="POST"
                onsubmit="return confirm('Delete this trip?')" style="display:inline">
            <button class="btn btn-danger btn-sm">🗑 Delete</button>
          </form>
        <% } %>
        <a href="/trips" class="btn btn-ghost btn-sm">← Back</a>
      </div>
    </div>
    <div class="page">

      <!-- Details -->
      <div class="card" style="margin-bottom:20px">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px">
          <div>
            <h2 style="font-size:22px;font-weight:800"><%= trip.name %></h2>
            <% if (trip.description) { %>
              <p style="color:var(--text2);margin-top:4px;max-width:600px"><%= trip.description %></p>
            <% } %>
          </div>
          <span class="badge b-<%= trip.status==='planned'?'blue':trip.status==='ongoing'?'green':trip.status==='completed'?'purple':'red' %>"
                style="font-size:13px;text-transform:capitalize;padding:5px 14px"><%= trip.status %></span>
        </div>
        <div class="detail-grid">
          <div class="detail-item">
            <label>📅 Start Date</label>
            <p><%= new Date(trip.startDate).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) %></p>
          </div>
          <div class="detail-item">
            <label>📅 End Date</label>
            <p><%= new Date(trip.endDate).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) %></p>
          </div>
          <div class="detail-item">
            <label>⏱ Duration</label>
            <p><%= trip.duration %> day(s)</p>
          </div>
          <div class="detail-item">
            <label>💰 Budget</label>
            <p><%= trip.budget ? '$' + trip.budget.toLocaleString() : 'Not set' %></p>
          </div>
          <div class="detail-item">
            <label>👤 Created by</label>
            <p><%= trip.user?.username || '—' %></p>
          </div>
          <% if (trip.tags && trip.tags.length) { %>
          <div class="detail-item" style="grid-column:1/-1">
            <label>🏷 Tags</label>
            <p><% trip.tags.forEach(t => { %><span class="tag"><%= t %></span><% }) %></p>
          </div>
          <% } %>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">

        <!-- Cities on this trip (many-to-many) -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">🏙️ Cities (<%= trip.cities.length %>)</div>
          </div>
          <% if (!trip.cities.length) { %>
            <p style="color:var(--text3);font-size:14px">No cities added yet.</p>
          <% } else { %>
            <% trip.cities.forEach(c => { %>
              <div style="display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border)">
                <div>
                  <a href="/cities/<%= c._id %>" style="font-size:14px;font-weight:600"><%= c.name %></a>
                  <div style="font-size:12px;color:var(--text3)"><%= c.country?.name || '' %></div>
                </div>
                <% if (canEdit) { %>
                  <form action="/trips/<%= trip._id %>/cities/<%= c._id %>?_method=DELETE" method="POST">
                    <button class="btn btn-danger btn-xs">✕</button>
                  </form>
                <% } %>
              </div>
            <% }) %>
          <% } %>

          <% if (canEdit && availableCities.length) { %>
          <form action="/trips/<%= trip._id %>/cities" method="POST" style="margin-top:14px;display:flex;gap:8px">
            <select name="cityId" style="flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);padding:8px 12px;font-size:13px">
              <% availableCities.forEach(c => { %>
                <option value="<%= c._id %>"><%= c.name %> (<%= c.country?.name || '?' %>)</option>
              <% }) %>
            </select>
            <button class="btn btn-cyan btn-sm">+ Add</button>
          </form>
          <% } %>
        </div>

        <!-- Activities (embedded sub-documents) -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">📋 Activities (<%= trip.activities.length %>)</div>
          </div>
          <% if (!trip.activities.length) { %>
            <p style="color:var(--text3);font-size:14px">No activities planned yet.</p>
          <% } else { %>
            <% trip.activities.forEach(a => { %>
              <div style="padding:8px 0;border-bottom:1px solid var(--border)">
                <div style="display:flex;justify-content:space-between;align-items:flex-start">
                  <div>
                    <div style="font-weight:600;font-size:14px"><%= a.name %></div>
                    <div style="font-size:12px;color:var(--text3)">
                      <% if (a.date) { %><%= new Date(a.date).toLocaleDateString() %><% } %>
                      <% if (a.time) { %> at <%= a.time %><% } %>
                      <% if (a.cost) { %> · $<%= a.cost %><% } %>
                    </div>
                    <% if (a.notes) { %><div style="font-size:12px;color:var(--text3);margin-top:2px"><%= a.notes %></div><% } %>
                  </div>
                  <% if (canEdit) { %>
                    <form action="/trips/<%= trip._id %>/activities/<%= a._id %>?_method=DELETE" method="POST">
                      <button class="btn btn-danger btn-xs">✕</button>
                    </form>
                  <% } %>
                </div>
              </div>
            <% }) %>
          <% } %>

          <!-- Add activity form -->
          <% if (canEdit) { %>
          <details style="margin-top:14px">
            <summary style="cursor:pointer;font-size:13px;color:var(--accent-h);font-weight:600">+ Add Activity</summary>
            <form action="/trips/<%= trip._id %>/activities" method="POST" style="margin-top:10px">
              <div class="form-grid g2" style="gap:10px">
                <div class="form-group" style="grid-column:1/-1">
                  <input type="text" name="name" required placeholder="Activity name *" />
                </div>
                <div class="form-group">
                  <input type="date" name="date" />
                </div>
                <div class="form-group">
                  <input type="time" name="time" />
                </div>
                <div class="form-group">
                  <input type="number" name="cost" placeholder="Cost ($)" min="0" />
                </div>
                <div class="form-group">
                  <input type="text" name="notes" placeholder="Notes" />
                </div>
              </div>
              <button type="submit" class="btn btn-primary btn-sm" style="margin-top:10px">Add Activity</button>
            </form>
          </details>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</div>
<%- include('../partials/foot') %>