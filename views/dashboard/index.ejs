<!-- Overlay backdrop for mobile sidebar -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<aside class="sidebar" id="sidebar">
  <!-- Close button inside sidebar -->
  <button class="sidebar-close-btn" id="sidebarCloseBtn" aria-label="Close menu">✕</button>
  
  <div class="sidebar-logo">
    <div class="logo-icon">✈️</div>
    <div>
      <span>TravelPlanner</span>
      <small>Explore the world</small>
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-label">Main</div>
    <a href="/dashboard" class="nav-link <%= activePage === 'dashboard' ? 'active' : '' %>">
      <span class="icon">🏠</span> Dashboard
    </a>

    <div class="nav-label">Travel</div>
    <a href="/trips" class="nav-link <%= activePage === 'trips' ? 'active' : '' %>">
      <span class="icon">🗺️</span> My Trips
    </a>
    <a href="/cities" class="nav-link <%= activePage === 'cities' ? 'active' : '' %>">
      <span class="icon">🏙️</span> Cities
    </a>
    <a href="/countries" class="nav-link <%= activePage === 'countries' ? 'active' : '' %>">
      <span class="icon">🌍</span> Countries
    </a>
    <a href="/themes/landing" class="nav-link <%= activePage === 'themes' ? 'active' : '' %>">
      <span class="icon">🎨</span> Themes
    </a>

    <% if (user && user.role === 'admin') { %>
    <div class="nav-label">Admin</div>
    <a href="/dashboard/users" class="nav-link <%= activePage === 'users' ? 'active' : '' %>">
      <span class="icon">👥</span> Users
    </a>
    <% } %>
  </nav>

  <div class="sidebar-footer">
    <% if (user) { %>
    <div class="user-card">
      <div class="user-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
      <div class="user-info">
        <div class="user-name"><%= user.username %></div>
        <div class="user-role"><%= user.role %></div>
      </div>
      <form action="/logout" method="GET">
        <button class="logout-btn" title="Logout">↩</button>
      </form>
    </div>
    <% } %>
  </div>
</aside>

<%- include('../partials/head') %>
<div class="app-shell">
  <div class="main-content">
    
    <div class="topbar">
      <div class="topbar-title">Dashboard</div>
      <div class="topbar-actions">
        <!-- REMOVED the second hamburger menu that was here -->
        <span style="font-size:13px;color:var(--text3);display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
          Hey, <strong style="color:var(--text)"><%= user?.username || 'Guest' %></strong>
          <span class="badge b-<%= user?.role === 'admin' ? 'purple' : 'cyan' %>" style="margin-left:0">
            <%= user?.role || 'user' %>
          </span>
        </span>
      </div>
    </div>

    <div class="page">
      
      <div class="dashboard-hero">
        <div class="hero-slider">
          <img src="/assets/beirout2.jpg" alt="Travel Banner" class="hero-img" />
          <img src="/assets/paris.jpg" alt="Paris" class="hero-img" />
          <img src="/assets/rome2.jpg" alt="Rome" class="hero-img" />
          <img src="/assets/tokyo.jpg" alt="Tokyo" class="hero-img" />
        </div>
        <div class="hero-overlay">
          <h2>Welcome back, <%= user?.username || 'Guest' %>!</h2>
          <p>Where are we traveling to next?</p>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon si-purple">🗺️</div>
          <div><div class="stat-val"><%= totalTrips %></div><div class="stat-label">My Trips</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon si-cyan">🏙️</div>
          <div><div class="stat-val"><%= totalCities %></div><div class="stat-label">Cities</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon si-green">🌍</div>
          <div><div class="stat-val"><%= totalCountries %></div><div class="stat-label">Countries</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon si-orange">⭐</div>
          <div><div class="stat-val"><%= bucketCount %></div><div class="stat-label">Bucket List</div></div>
        </div>

        <% if (totalUsers !== null) { %>
        <div class="stat-card">
          <div class="stat-icon si-purple">👥</div>
          <div><div class="stat-val"><%= totalUsers %></div><div class="stat-label">Total Users</div></div>
        </div>
        <% } %>
      </div>

      <div class="dashboard-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:22px">

        <div class="card">
          <div class="card-header">
            <div class="card-title">📊 Trip Status</div>
          </div>

          <% if (!statusBreakdown.length) { %>
            <p style="color:var(--text3);font-size:14px">No trips yet.</p>
          <% } else { %>
            <% const total = statusBreakdown.reduce((s,x)=>s+x.count,0) %>
            <% statusBreakdown.forEach(s => { %>
              <% const pct = Math.round(s.count/total*100) %>
              <% const col = s._id==='planned'?'#60a5fa':s._id==='ongoing'?'#4ade80':s._id==='completed'?'#a78bfa':'#f87171' %>

              <div style="margin-bottom:13px">
                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px">
                  <span style="text-transform:capitalize;color:<%= col %>"><%= s._id %></span>
                  <span style="color:var(--text2)"><%= s.count %> (<%= pct %>%)</span>
                </div>
                <div style="background:var(--bg3);border-radius:999px;height:6px">
                  <div style="height:100%;border-radius:999px;width:<%= pct %>%;background:<%= col %>"></div>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>

        <div class="card">
          <div class="card-header">
            <div class="card-title">📍 Popular Cities</div>
            <a href="/cities" class="btn btn-ghost btn-sm">View all →</a>
          </div>

          <% if (!popularCities.length) { %>
            <p style="color:var(--text3);font-size:14px">No cities yet.</p>
          <% } else { %>
            <% popularCities.forEach(c => { 
              const cityImage = c.image || '/assets/default-city.jpg';
            %>
            <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)">
              <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0">
                <img src="<%= cityImage %>" 
                     style="width:36px;height:36px;border-radius:8px;object-fit:cover;flex-shrink:0" 
                     onerror="this.src='/assets/default-city.jpg'" />
                <div style="min-width:0">
                  <a href="/cities/<%= c._id %>" style="font-size:13px;font-weight:600;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= c.name %></a>
                  <div style="font-size:11px;color:var(--text3)"><%= c.country?.name || '—' %></div>
                </div>
              </div>
              <span style="font-size:11px;color:var(--text3);flex-shrink:0"><%= c.visitors?.length || 0 %> saved</span>
            </div>
            <% }) %>
          <% } %>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <div class="card-title">✈️ Recent Trips</div>
          <a href="/trips/new" class="btn btn-primary btn-sm">+ New Trip</a>
        </div>

        <% if (!myTrips.length) { %>
          <div class="empty">
            <div class="ei">🗺️</div>
            <p>No trips yet. <a href="/trips/new">Plan your first one!</a></p>
          </div>
        <% } else { %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr><th>Trip</th><th>Cities</th><th>Dates</th><th>Status</th><th>Budget</th></tr>
              </thead>
              <tbody>
                <% myTrips.forEach(t => { %>
                <tr>
                  <td><a href="/trips/<%= t._id %>"><%= t.name %></a></td>
                  <td style="color:var(--text3);font-size:12px"><%= t.cities.map(c=>c.name).join(', ') || '—' %></td>
                  <td style="color:var(--text3);font-size:12px">
                    <%= new Date(t.startDate).toLocaleDateString() %> → <%= new Date(t.endDate).toLocaleDateString() %>
                  </td>
                  <td><span class="s-<%= t.status %>" style="font-size:12px;font-weight:600;text-transform:capitalize"><%= t.status %></span></td>
                  <td style="color:var(--text3)"><%= t.budget ? '$'+t.budget.toLocaleString() : '—' %></td>
                </tr>
                <% }) %>
              </tbody>
            <table>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</div>

<script>
  // Close button inside sidebar - closes the sidebar
  (function() {
    const closeBtn = document.getElementById('sidebarCloseBtn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    
    function closeSidebar() {
      if (sidebar) sidebar.classList.remove('open');
      if (hamburgerBtn) hamburgerBtn.classList.remove('open');
      if (overlay) overlay.classList.remove('active');
      document.body.style.overflow = '';
    }
    
    if (closeBtn) {
      closeBtn.addEventListener('click', closeSidebar);
    }
  })();
</script>

<%- include('../partials/foot') %>