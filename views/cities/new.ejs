<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title">New City</div>
      <a href="/cities" class="btn btn-ghost btn-sm">← Back</a>
    </div>
    <div class="page">
      <div class="card form-card">
        <% if (error) { %><div class="alert alert-error">⚠️ <%= error %></div><% } %>
        <form action="/cities" method="POST">
          <div class="form-grid g2">
            <div class="form-group" style="grid-column:1/-1">
              <label>Image URL</label>
              <input type="text" name="image" placeholder="/assets/paris.jpg" />
              <small style="color:var(--text3)">Enter a public image URL (optional)</small>
            </div>
            <div class="form-group">
              <label>City Name *</label>
              <input type="text" name="name" required placeholder="Paris" />
            </div>
            <div class="form-group">
              <label>Country *</label>
              <select name="country" required>
                <option value="">Select country…</option>
                <% countries.forEach(c => { %>
                  <option value="<%= c._id %>"><%= c.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>Population</label>
              <input type="number" name="population" placeholder="2000000" min="0" />
            </div>
            <div class="form-group">
              <label>Timezone</label>
              <input type="text" name="timezone" placeholder="Europe/Paris" />
            </div>
            <div class="form-group">
              <label>Language</label>
              <input type="text" name="language" placeholder="French" />
            </div>
            <div class="form-group">
              <label>Currency</label>
              <input type="text" name="currency" placeholder="EUR" />
            </div>
          </div>
          <div class="form-actions" style="margin-top:20px">
            <button type="submit" class="btn btn-primary">Create City</button>
            <a href="/cities" class="btn btn-ghost">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>