<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title">New Country</div>
      <a href="/countries" class="btn btn-ghost btn-sm">← Back</a>
    </div>
    <div class="page">
      <div class="card form-card">
        <% if (error) { %><div class="alert alert-error">⚠️ <%= error %></div><% } %>
        <form action="/countries" method="POST">
          <div class="form-grid g2">
            <div class="form-group" style="grid-column:1/-1">
              <label>Country Image URL</label>
              <input type="text" name="image" placeholder="/assets/france.jpg" />
              <small style="color:var(--text3)">Enter a public image URL (optional)</small>
            </div>
            <div class="form-group">
              <label>Country Name *</label>
              <input type="text" name="name" required placeholder="France" />
            </div>
            <div class="form-group">
              <label>Country Code</label>
              <input type="text" name="code" placeholder="FR" maxlength="3" />
            </div>
          </div>
          <div class="form-actions" style="margin-top:20px">
            <button type="submit" class="btn btn-primary">Create Country</button>
            <a href="/countries" class="btn btn-ghost">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>