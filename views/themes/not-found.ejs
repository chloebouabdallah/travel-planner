<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title">Theme Not Found</div>
      <a href="/themes/landing" class="btn btn-ghost btn-sm">← Back</a>
    </div>
    <div class="page">
      <div class="card" style="text-align:center;padding:60px 40px">
        <div style="font-size:60px;margin-bottom:20px">🎨</div>
        <h2 style="font-size:24px;font-weight:800;margin-bottom:12px">
          This theme hasn't been created yet
        </h2>
        <p style="color:var(--text2);margin-bottom:8px">
          The "<%= slug.split('-').map(w => w.charAt(0).toUpperCase()+w.slice(1)).join(' ') %>"
          theme doesn't exist in the database yet.
        </p>
        <% if (user && user.role === 'admin') { %>
          <p style="color:var(--text3);font-size:13px;margin-bottom:24px">
            As admin, you can create it now.
          </p>
          <a href="/themes/new" class="btn btn-primary">+ Create This Theme</a>
        <% } else { %>
          <p style="color:var(--text3);font-size:14px;margin-top:12px">
            This theme is coming soon. Check back later!
          </p>
          <a href="/themes/landing" class="btn btn-ghost" style="margin-top:20px">← Go Back</a>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>