<%- include('../partials/head') %>
<style>
  .landing-hero { min-height:90vh; background:linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)),url('/assets/cappadocia.webp') center/cover no-repeat; display:flex; align-items:center; justify-content:center; text-align:center; color:white; }
  .landing-hero-content { max-width:800px; padding:40px; }
  .landing-hero-title { font-size:56px; font-weight:800; margin-bottom:20px; }
  .landing-hero-subtitle { font-size:20px; opacity:0.95; }
  .theme-section { padding:80px 40px; max-width:1200px; margin:0 auto; display:flex; gap:50px; align-items:center; flex-wrap:wrap; border-bottom:1px solid var(--border); }
  .theme-section.reverse { flex-direction:row-reverse; }
  .theme-section:last-child { border-bottom:none; }
  .theme-content { flex:1; min-width:280px; }
  .theme-icon { font-size:48px; margin-bottom:16px; }
  .theme-title { font-size:36px; font-weight:800; margin-bottom:16px; color:var(--text); }
  .theme-subtitle { font-size:18px; color:var(--accent); font-weight:600; margin-bottom:16px; }
  .theme-description { color:var(--text2); line-height:1.8; font-size:16px; margin-bottom:24px; }
  .theme-image { flex:1; min-width:280px; border-radius:20px; overflow:hidden; box-shadow:0 20px 40px rgba(0,0,0,0.1); }
  .theme-image img { width:100%; height:350px; object-fit:cover; transition:transform 0.3s ease; }
  .theme-image:hover img { transform:scale(1.05); }
  .fade-scroll { opacity:0; transform:translateY(30px); transition:all 0.6s ease; }
  .fade-scroll.visible { opacity:1; transform:translateY(0); }
  @media (max-width:768px) {
    .landing-hero-title { font-size:36px; }
    .theme-title { font-size:28px; }
    .theme-section { flex-direction:column !important; padding:50px 20px; }
  }
</style>

<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title">Travel Themes</div>
      <div style="display:flex;gap:10px">
        <% if (user && user.role === 'admin') { %>
          <a href="/themes/new" class="btn btn-primary">+ New Theme</a>
        <% } %>
        <a href="/themes" class="btn btn-ghost btn-sm">View All →</a>
      </div>
    </div>
    <div class="page" style="padding:0">

      <section class="landing-hero">
        <div class="landing-hero-content">
          <h1 class="landing-hero-title">Find Your Perfect Escape</h1>
          <p class="landing-hero-subtitle">Discover travel experiences tailored to your passion and style</p>
        </div>
      </section>

      <!-- Civil Marriage -->
      <section class="theme-section fade-scroll">
        <div class="theme-content">
          <div class="theme-icon">💍</div>
          <h2 class="theme-title">Civil Marriage</h2>
          <p class="theme-subtitle">Romantic ceremonies and legal weddings abroad</p>
          <p class="theme-description">Plan your dream civil marriage in breathtaking destinations around the world. From beachfront ceremonies to historic venues, we help you create unforgettable memories.</p>
          <a href="/themes/civil-marriage" class="btn btn-primary">Explore Now →</a>
        </div>
        <div class="theme-image"><img src="/assets/pafos.jpeg" alt="Civil Marriage" /></div>
      </section>

      <!-- Honeymoon -->
      <section class="theme-section fade-scroll reverse">
        <div class="theme-content">
          <div class="theme-icon">🌹</div>
          <h2 class="theme-title">Honeymoon</h2>
          <p class="theme-subtitle">Dreamy destinations for your perfect romantic getaway</p>
          <p class="theme-description">Celebrate your love in the most romantic destinations on earth. From overwater bungalows in Bora Bora to vineyard escapes in Tuscany.</p>
          <a href="/themes/honeymoon" class="btn btn-primary">Explore Now →</a>
        </div>
        <div class="theme-image"><img src="/assets/venice.jpg" alt="Honeymoon" /></div>
      </section>

      <!-- Girls Trip -->
      <section class="theme-section fade-scroll">
        <div class="theme-content">
          <div class="theme-icon">👯</div>
          <h2 class="theme-title">Girls Trip</h2>
          <p class="theme-subtitle">Fun-filled adventures with your best friends</p>
          <p class="theme-description">Grab your besties and explore vibrant cities, relax on tropical beaches, or indulge in spa retreats designed for unforgettable group experiences.</p>
          <a href="/themes/girls-trip" class="btn btn-primary">Explore Now →</a>
        </div>
        <div class="theme-image"><img src="/assets/greece2.jpeg" alt="Girls Trip" /></div>
      </section>

      <!-- Festival Escapes -->
      <section class="theme-section fade-scroll reverse">
        <div class="theme-content">
          <div class="theme-icon">🎉</div>
          <h2 class="theme-title">Festival Escapes</h2>
          <p class="theme-subtitle">Celebrate traditions and joy around the world</p>
          <p class="theme-description">Experience the world's most vibrant festivals — from Carnival in Rio to Oktoberfest in Munich, and Diwali in India to Songkran in Thailand.</p>
          <a href="/themes/festival-escapes" class="btn btn-primary">Explore Now →</a>
        </div>
        <div class="theme-image"><img src="/assets/brazil.jpeg" alt="Festival Escapes" /></div>
      </section>

      <section class="fade-scroll" style="text-align:center;padding:80px 40px;background:var(--bg3)">
        <h2 style="font-size:32px;margin-bottom:16px">Ready to start your journey?</h2>
        <p style="color:var(--text2);margin-bottom:30px">Join thousands of travelers who organize their adventures with TravelPlanner.</p>
        <a href="/trips/new" class="btn btn-primary">Plan a Trip</a>
      </section>

      <footer style="background:var(--bg2);border-top:1px solid var(--border);padding:40px;text-align:center;color:var(--text3)">
        <p>© 2024 TravelPlanner. All rights reserved.</p>
      </footer>
    </div>
  </div>
</div>

<script>
  const fadeElements = document.querySelectorAll('.fade-scroll');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
      else entry.target.classList.remove('visible');
    });
  }, { threshold: 0.15 });
  fadeElements.forEach(el => observer.observe(el));
</script>
<%- include('../partials/foot') %>