<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title">Edit Theme</div>
      <a href="/themes/<%= theme.slug %>" class="btn btn-ghost btn-sm">← Back</a>
    </div>
    <div class="page">
      <div class="card form-card">
        <% if (error) { %><div class="alert alert-error">⚠️ <%= error %></div><% } %>
        <form action="/themes/<%= theme._id %>?_method=PUT" method="POST">
          <div class="form-grid g2">
            <div class="form-group">
              <label>Theme Name *</label>
              <select name="name" required>
                <option value="Civil Marriage"   <%= theme.name === 'Civil Marriage'   ? 'selected' : '' %>>💍 Civil Marriage</option>
                <option value="Honeymoon"        <%= theme.name === 'Honeymoon'        ? 'selected' : '' %>>🌹 Honeymoon</option>
                <option value="Girls Trip"       <%= theme.name === 'Girls Trip'       ? 'selected' : '' %>>👯 Girls Trip</option>
                <option value="Festival Escapes" <%= theme.name === 'Festival Escapes' ? 'selected' : '' %>>🎉 Festival Escapes</option>
              </select>
            </div>
            <div class="form-group">
              <label>Status</label>
              <select name="isActive">
                <option value="on" <%= theme.isActive  ? 'selected' : '' %>>Active</option>
                <option value=""   <%= !theme.isActive ? 'selected' : '' %>>Inactive</option>
              </select>
            </div>
            <div class="form-group" style="grid-column:1/-1">
              <label>Title *</label>
              <input type="text" name="title" required value="<%= theme.title %>" />
            </div>
            <div class="form-group" style="grid-column:1/-1">
              <label>Subtitle *</label>
              <input type="text" name="subtitle" required value="<%= theme.subtitle %>" />
            </div>
            <div class="form-group" style="grid-column:1/-1">
              <label>Description *</label>
              <textarea name="description" rows="4" required><%= theme.description %></textarea>
            </div>
            <div class="form-group" style="grid-column:1/-1">
              <label>Image URL</label>
              <input type="text" name="image" value="<%= theme.image || '' %>" />
            </div>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/themes/<%= theme.slug %>" class="btn btn-ghost">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>